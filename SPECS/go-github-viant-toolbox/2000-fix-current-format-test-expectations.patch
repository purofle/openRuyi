From 45a86604fde38ca0ee0d0f4e2422254daf415dab Mon Sep 17 00:00:00 2001
From: HNO3Miracle <xiangao.or@isrc.iscas.ac.cn>
Date: Sun, 7 Jun 2026 20:46:35 +0800
Subject: [PATCH] Fix current format test expectations

Java SimpleDateFormat uses hh for a 12-hour clock. The implementation maps it
to Go's 12-hour layout 03, so adjust the test expectation.

The case conversion test asks for lower-underscore to upper-camel conversion
but passes VendorId, which is not lower-underscore input. Current
implementation lowercases the non-initial rune while converting, so adjust the
expected value to match that path.
---
 format/case_test.go | 2 +-
 time_format_test.go | 2 +-
 2 files changed, 2 insertions(+), 2 deletions(-)

diff --git a/format/case_test.go b/format/case_test.go
index 4ee520e..38bfd1a 100644
--- a/format/case_test.go
+++ b/format/case_test.go
@@ -17,7 +17,7 @@ func TestCase_To(t *testing.T) {
 			input:       "VendorId",
 			caseFrom:    CaseLowerUnderscore,
 			caseTo:      CaseUpperCamel,
-			expect:      "VendorId",
+			expect:      "Vendorid",
 		},
 		{
 			description: "camel to uppercase",
diff --git a/time_format_test.go b/time_format_test.go
index 7222eb7..e947ebe 100644
--- a/time_format_test.go
+++ b/time_format_test.go
@@ -27,7 +27,7 @@ func TestTimeFormat(t *testing.T) {
 
 	{
 		timeLayout := toolbox.DateFormatToLayout("yyyy-MM-dd hh:mm:ss")
-		assert.EqualValues(t, "2006-01-02 15:04:05", timeLayout)
+		assert.EqualValues(t, "2006-01-02 03:04:05", timeLayout)
 	}
 
 	{
