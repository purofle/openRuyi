From fe5e31d0281c1fc43054eb1f1dc4d94667b5af0f Mon Sep 17 00:00:00 2001
From: misaka00251 <liuxin@iscas.ac.cn>
Date: Tue, 6 Jan 2026 00:28:19 +0800
Subject: [PATCH] Set GO111MODULE on

---
 cmd/gonew/main_test.go                           | 2 +-
 go/analysis/internal/versiontest/version_test.go | 6 +++---
 go/analysis/unitchecker/separate_test.go         | 1 +
 gopls/internal/cmd/integration_test.go           | 8 ++++----
 internal/refactor/inline/everything_test.go      | 2 +-
 internal/refactor/inline/inline_test.go          | 2 +-
 6 files changed, 11 insertions(+), 10 deletions(-)

diff --git a/cmd/gonew/main_test.go b/cmd/gonew/main_test.go
index 142788b..7fac870 100644
--- a/cmd/gonew/main_test.go
+++ b/cmd/gonew/main_test.go
@@ -87,7 +87,7 @@ func Test(t *testing.T) {
 			}
 			cmd := exec.Command(exe, args[1:]...)
 			cmd.Dir = out
-			cmd.Env = append(os.Environ(), "TestGonewMain=1", "GOPROXY="+proxyURL, "GOSUMDB=off")
+			cmd.Env = append(os.Environ(), "TestGonewMain=1", "GOPROXY="+proxyURL, "GOSUMDB=off", "GO111MODULE=auto")
 			var stdout bytes.Buffer
 			var stderr bytes.Buffer
 			cmd.Stdout = &stdout
diff --git a/go/analysis/internal/versiontest/version_test.go b/go/analysis/internal/versiontest/version_test.go
index a594ad2..bd95e7e 100644
--- a/go/analysis/internal/versiontest/version_test.go
+++ b/go/analysis/internal/versiontest/version_test.go
@@ -69,7 +69,7 @@ func TestMultichecker(t *testing.T) {
 	}
 	cmd := exec.Command(exe, ".")
 	cmd.Dir = testDir(t)
-	cmd.Env = append(os.Environ(), "VERSIONTEST_MULTICHECKER=1")
+	cmd.Env = append(os.Environ(), "VERSIONTEST_MULTICHECKER=1", "GO111MODULE=auto")
 	out, err := cmd.CombinedOutput()
 	if err == nil || !strings.Contains(string(out), "x.go:1:1: goversion=go1.20") {
 		t.Fatalf("multichecker: %v\n%s", err, out)
@@ -85,7 +85,7 @@ func TestSinglechecker(t *testing.T) {
 	}
 	cmd := exec.Command(exe, ".")
 	cmd.Dir = testDir(t)
-	cmd.Env = append(os.Environ(), "VERSIONTEST_SINGLECHECKER=1")
+	cmd.Env = append(os.Environ(), "VERSIONTEST_SINGLECHECKER=1", "GO111MODULE=auto")
 	out, err := cmd.CombinedOutput()
 	if err == nil || !strings.Contains(string(out), "x.go:1:1: goversion=go1.20") {
 		t.Fatalf("multichecker: %v\n%s", err, out)
@@ -101,7 +101,7 @@ func TestVettool(t *testing.T) {
 	}
 	cmd := exec.Command("go", "vet", "-vettool="+exe, ".")
 	cmd.Dir = testDir(t)
-	cmd.Env = append(os.Environ(), "VERSIONTEST_MULTICHECKER=1")
+	cmd.Env = append(os.Environ(), "VERSIONTEST_MULTICHECKER=1", "GO111MODULE=auto")
 	out, err := cmd.CombinedOutput()
 	if err == nil || !strings.Contains(string(out), "x.go:1:1: goversion=go1.20") {
 		t.Fatalf("vettool: %v\n%s", err, out)
diff --git a/go/analysis/unitchecker/separate_test.go b/go/analysis/unitchecker/separate_test.go
index 2198154..4ac3ee7 100644
--- a/go/analysis/unitchecker/separate_test.go
+++ b/go/analysis/unitchecker/separate_test.go
@@ -94,6 +94,7 @@ func MyPrintf(format string, args ...any) {
 		Mode: packages.NeedName | packages.NeedFiles | packages.NeedCompiledGoFiles | packages.NeedImports | packages.NeedModule,
 		Dir:  tmpdir,
 		Env: append(os.Environ(),
+			"GO111MODULE=on", // needs Go module to work
 			"GOPROXY=off", // disable network
 			"GOWORK=off",  // an ambient GOWORK value would break package loading
 		),
diff --git a/gopls/internal/cmd/integration_test.go b/gopls/internal/cmd/integration_test.go
index a097e73..33eaa4e 100644
--- a/gopls/internal/cmd/integration_test.go
+++ b/gopls/internal/cmd/integration_test.go
@@ -233,7 +233,7 @@ func TestFail(t *testing.T) { t.Fatal("fail") }
 	}
 	// list code lenses
 	{
-		res := gopls(t, tree, "codelens", "./a/a_test.go")
+		res := goplsWithEnv(t, tree, []string{"GO111MODULE=on"}, "codelens", "./a/a_test.go")
 		res.checkExit(true)
 		res.checkStdout(`a_test.go:3: "run test" \[gopls.run_tests\]`)
 		res.checkStdout(`a_test.go:4: "run test" \[gopls.run_tests\]`)
@@ -246,14 +246,14 @@ func TestFail(t *testing.T) { t.Fatal("fail") }
 	}
 	// run the passing test
 	{
-		res := gopls(t, tree, "-v", "codelens", "-exec", "./a/a_test.go:3", "run test")
+		res := goplsWithEnv(t, tree, []string{"GO111MODULE=on"}, "-v", "codelens", "-exec", "./a/a_test.go:3", "run test")
 		res.checkExit(true)
 		res.checkStderr(`PASS: TestPass`)         // from go test
 		res.checkStderr("Info: all tests passed") // from gopls.test
 	}
 	// run the failing test
 	{
-		res := gopls(t, tree, "codelens", "-exec", "./a/a_test.go:4", "run test")
+		res := goplsWithEnv(t, tree, []string{"GO111MODULE=on"}, "codelens", "-exec", "./a/a_test.go:4", "run test")
 		res.checkExit(false)
 		res.checkStderr(`FAIL	example.com/a`)
 		res.checkStderr("Info: 1 / 1 tests failed")
@@ -378,7 +378,7 @@ func TestHello(t *testing.T) {
 	// run tests
 	{
 		helloTest := "file://" + filepath.ToSlash(tree) + "/hello_test.go"
-		res := gopls(t, tree, "execute", "gopls.run_tests", `{"URI": "`+helloTest+`", "Tests": ["TestHello"]}`)
+		res := goplsWithEnv(t, tree, []string{"GO111MODULE=on"}, "execute", "gopls.run_tests", `{"URI": "`+helloTest+`", "Tests": ["TestHello"]}`)
 		res.checkExit(false)
 		res.checkStderr(`hello_test.go:4: oops`)
 		res.checkStderr(`1 / 1 tests failed`)
diff --git a/internal/refactor/inline/everything_test.go b/internal/refactor/inline/everything_test.go
index aecaa7d..4f27de3 100644
--- a/internal/refactor/inline/everything_test.go
+++ b/internal/refactor/inline/everything_test.go
@@ -60,7 +60,7 @@ func TestEverything(t *testing.T) {
 	cfg := &packages.Config{
 		Mode: packages.LoadAllSyntax,
 		Env: append(os.Environ(),
-			"GO111MODULES=on",
+			"GO111MODULE=on",
 			"GOPATH=",
 			"GOWORK=off",
 			"GOPROXY=off"),
diff --git a/internal/refactor/inline/inline_test.go b/internal/refactor/inline/inline_test.go
index 0a1129a..3cad1c5 100644
--- a/internal/refactor/inline/inline_test.go
+++ b/internal/refactor/inline/inline_test.go
@@ -97,7 +97,7 @@ func TestData(t *testing.T) {
 				Dir:  dir,
 				Mode: packages.LoadAllSyntax,
 				Env: append(os.Environ(),
-					"GO111MODULES=on",
+					"GO111MODULE=on",
 					"GOPATH=",
 					"GOWORK=off",
 					"GOPROXY=off"),
-- 
2.52.0

