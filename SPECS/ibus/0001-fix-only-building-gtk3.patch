From 13d63f2ec9943d406bd991963d8c6e82e776e6c7 Mon Sep 17 00:00:00 2001
From: fujiwarat <takao.fujiwara1@gmail.com>
Date: Wed, 11 Mar 2026 20:42:06 +0900
Subject: [PATCH] src/tests: Fix only GTK3 builds

Add TEST_GTK_VERSION environment.
Also fix ibus-compose test failure to unset NO_LOAD_COMPOSE_FILE.

BUG=https://github.com/ibus/ibus/issues/2859
---
 src/tests/Makefile.am |  4 ++-
 src/tests/runtest     | 57 ++++++++++++++++++++++++++-----------------
 2 files changed, 37 insertions(+), 24 deletions(-)

diff --git a/src/tests/Makefile.am b/src/tests/Makefile.am
index 1a63917fc..360d9632f 100644
--- a/src/tests/Makefile.am
+++ b/src/tests/Makefile.am
@@ -3,7 +3,7 @@
 # ibus - The Input Bus
 #
 # Copyright (c) 2007-2015 Peng Huang <shawn.p.huang@gmail.com>
-# Copyright (c) 2015-2025 Takao Fujiwara <takao.fujiwara1@gmail.com>
+# Copyright (c) 2015-2026 Takao Fujiwara <takao.fujiwara1@gmail.com>
 # Copyright (c) 2007-2025 Red Hat, Inc.
 #
 # This library is free software; you can redistribute it and/or
@@ -216,10 +216,12 @@ ibus_compose_SOURCES = ibus-compose.c
 if ENABLE_GTK4
 ibus_compose_CFLAGS = @GTK4_CFLAGS@
 ibus_compose_LDADD = $(prog_ldadd) @GTK4_LIBS@
+TESTS_ENVIRONMENT += TEST_GTK_VERSION=4
 else
 if ENABLE_GTK3
 ibus_compose_CFLAGS = @GTK3_CFLAGS@
 ibus_compose_LDADD = $(prog_ldadd) @GTK3_LIBS@
+TESTS_ENVIRONMENT += TEST_GTK_VERSION=3
 endif
 endif
 
diff --git a/src/tests/runtest b/src/tests/runtest
index e10093017..7b994a81e 100755
--- a/src/tests/runtest
+++ b/src/tests/runtest
@@ -23,6 +23,7 @@
 : ${srcdir:=.}
 : ${DISABLE_GUI_TESTS:=''}
 : ${DISABLE_DAEMONIZE_IN_TESTS:=''}
+: ${TEST_GTK_VERSION:=0}
 
 BUS_REQUIRED_TESTS="
 ibus-bus
@@ -140,30 +141,38 @@ run_test_case()
         IBUS_ADDRESS_FILE=$PWD/ibus-daemon.pid
         export IBUS_ADDRESS_FILE
 
-        if test -f "../$top_builddir/client/gtk4/.libs/libim-ibus.so" ; then
-            IM_IBUS_SO="../$top_builddir/client/gtk4/.libs/libim-ibus.so"
-        elif test -f "../$top_builddir/client/gtk4/libim-ibus.so" ; then
-            IM_IBUS_SO="../$top_builddir/client/gtk4/libim-ibus.so"
-        else
-            echo "NOT FOUND $top_builddir/client/gtk4/libim-ibus.so"
-            exit 1
-        fi
-        mkdir -p "$PWD/lib/gtk-4.0/immodules"
-        cp "$IM_IBUS_SO" "$PWD/lib/gtk-4.0/immodules/."
-        export GTK_EXE_PREFIX="$PWD"
-
-        if test -f "../$top_builddir/client/gtk3/.libs/im-ibus.so" ; then
-            IM_IBUS_SO="../$top_builddir/client/gtk3/.libs/im-ibus.so"
-        elif test -f "../$top_builddir/client/gtk3/im-ibus.so" ; then
-            IM_IBUS_SO="../$top_builddir/client/gtk3/im-ibus.so"
-        else
-            echo "NOT FOUND $top_builddir/client/gtk3/im-ibus.so"
+        case $TEST_GTK_VERSION in
+        4)
+            if test -f "../$top_builddir/client/gtk4/.libs/libim-ibus.so" ; then
+                IM_IBUS_SO="../$top_builddir/client/gtk4/.libs/libim-ibus.so"
+            elif test -f "../$top_builddir/client/gtk4/libim-ibus.so" ; then
+                IM_IBUS_SO="../$top_builddir/client/gtk4/libim-ibus.so"
+            else
+                echo "NOT FOUND $top_builddir/client/gtk4/libim-ibus.so"
+                exit 1
+            fi
+            mkdir -p "$PWD/lib/gtk-4.0/immodules"
+            cp "$IM_IBUS_SO" "$PWD/lib/gtk-4.0/immodules/."
+            export GTK_EXE_PREFIX="$PWD"
+            ;;
+        3)
+            if test -f "../$top_builddir/client/gtk3/.libs/im-ibus.so" ; then
+                IM_IBUS_SO="../$top_builddir/client/gtk3/.libs/im-ibus.so"
+            elif test -f "../$top_builddir/client/gtk3/im-ibus.so" ; then
+                IM_IBUS_SO="../$top_builddir/client/gtk3/im-ibus.so"
+            else
+                echo "NOT FOUND $top_builddir/client/gtk3/im-ibus.so"
+                exit 1
+            fi
+            GTK_IM_MODULE_FILE=$PWD/imcache
+            export GTK_IM_MODULE_FILE
+            $GTK_QUERY_MODULE "$IM_IBUS_SO" > $GTK_IM_MODULE_FILE
+            ;;
+        *)
+            echo "NOT SUPPORT GTK_VERSION $TEST_GTK_VERSION"
             exit 1
-        fi
-
-        GTK_IM_MODULE_FILE=$PWD/imcache
-        export GTK_IM_MODULE_FILE
-        $GTK_QUERY_MODULE "$IM_IBUS_SO" > $GTK_IM_MODULE_FILE
+            ;;
+        esac
 
         cp "../$top_srcdir/data/dconf/$IBUS_SCHEMA_FILE" $PWD
         glib-compile-schemas $PWD
@@ -235,6 +244,8 @@ else
         if test x"$first" = x"#" ; then
             continue
         fi
+        unset NO_LOAD_COMPOSE_FILE
+        unset COMPOSE_FILE
         export $e
         echo "Run `func_basename $tst` on $e"
         echo "======================="
