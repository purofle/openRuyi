+                return PROVIDER_INFO(sha1_ctx_mgr_flush_rvv);
+#endif
+        return PROVIDER_BASIC(_sha1_ctx_mgr_flush);
+}
diff --git a/sha1_mb/riscv64/sha1_riscv64_x1.S b/sha1_mb/riscv64/sha1_riscv64_x1.S
