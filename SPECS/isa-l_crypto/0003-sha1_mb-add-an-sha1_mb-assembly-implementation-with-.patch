+DEFINE_INTERFACE_DISPATCHER(_sha1_ctx_mgr_submit)
+{
+#if HAVE_RVV
+        const unsigned long hwcap = getauxval(AT_HWCAP);
+        if (hwcap & HWCAP_RV('V'))
+                return PROVIDER_INFO(sha1_ctx_mgr_submit_rvv);
+#endif
+        return PROVIDER_BASIC(_sha1_ctx_mgr_submit);
+}
