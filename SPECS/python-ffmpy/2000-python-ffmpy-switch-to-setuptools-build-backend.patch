From 2d7a75b9515e97eb6038605c664c62106c13c040 Mon Sep 17 00:00:00 2001
From: HNO3Miracle <xiangao.or@isrc.iscas.ac.cn>
Date: Tue, 14 Apr 2026 18:51:38 +0800
Subject: [PATCH] python-ffmpy: switch to setuptools backend

---
 pyproject.toml | 26 ++++++++++++++++++--------
 1 file changed, 18 insertions(+), 8 deletions(-)

diff --git a/pyproject.toml b/pyproject.toml
index e0d2ce8..c3110eb 100644
--- a/pyproject.toml
+++ b/pyproject.toml
@@ -2,12 +2,9 @@
 name = "ffmpy"
 version = "1.0.0"
 description = "A simple Python wrapper for FFmpeg"
-authors = [{ name = "Andrii Yurchuk", email = " <ay@mntw.re>" }]
+authors = [{ name = "Andrii Yurchuk", email = "ay@mntw.re" }]
 license = "MIT"
 readme = "README.rst"
-homepage = "https://github.com/Ch00k/ffmpy"
-repository = "https://github.com/Ch00k/ffmpy"
-documentation = "https://ffmpy.readthedocs.io"
 requires-python = ">=3.9"
 keywords = [
   "ffmpeg",
@@ -26,7 +23,6 @@
   "Topic :: Multimedia :: Video",
   "Development Status :: 5 - Production/Stable",
   "Intended Audience :: Developers",
-  "License :: OSI Approved :: MIT License",
   "Natural Language :: English",
   "Programming Language :: Python :: 3",
   "Programming Language :: Python :: 3.9",
@@ -43,7 +39,23 @@
   "Operating System :: POSIX :: Linux",
   "Operating System :: MacOS :: MacOS X",
 ]
-packages = [{ include = "ffmpy" }]
+[tool.setuptools.packages.find]
+# setuptools.build_meta does not understand uv_build's package layout table.
+include = ["ffmpy*"]
+
+[tool.setuptools.package-data]
+# Preserve the typing marker shipped by upstream.
+ffmpy = ["py.typed"]
+
+[tool.setuptools]
+# The project is package-only and does not ship standalone top-level modules.
+py-modules = []
+
+[project.urls]
+# setuptools validates URLs from the standard PEP 621 table, not legacy keys.
+Homepage = "https://github.com/Ch00k/ffmpy"
+Repository = "https://github.com/Ch00k/ffmpy"
+Documentation = "https://ffmpy.readthedocs.io"
 
 [project.optional-dependencies]
 psutil = [
@@ -73,8 +85,8 @@
 show_column_numbers = true
 
 [build-system]
-requires = ["uv_build>=0.7.9,<0.10.0"]
-build-backend = "uv_build"
+requires = ["setuptools>=69"]
+build-backend = "setuptools.build_meta"
 
 [tool.uv.build-backend]
 module-root = ""
-- 
2.43.0
